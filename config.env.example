# Claw Operator's Council Toolkit — Configuration Template
# Copy this file to config.env and fill in your values.
# Environment variables take precedence over values in this file.

# ---------------------------------------------------------------------------
# xAI API (REQUIRED)
# ---------------------------------------------------------------------------
# Get your key at: https://console.x.ai
#
# The skill checks these sources in order:
#   1. XAI_API_KEY environment variable (or this file)
#   2. ~/.xai-key (one line, no quotes)
#   3. ~/.openclaw/openclaw.json (if stored there)
# ---------------------------------------------------------------------------
XAI_API_KEY=YOUR_XAI_API_KEY_HERE

# ---------------------------------------------------------------------------
# Discord — Human-Facing Output Sink (OPTIONAL)
# ---------------------------------------------------------------------------
# Configure this if you want council verdicts posted to a Discord channel.
# Without this, results only go to your terminal.
#
# Option A: Webhook (simplest, no bot required)
# ---------------------------------------------------------------------------
# COUNCIL_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL

# Option B: Native Discord (requires OpenClaw Discord channel configured)
# Get these IDs by enabling Discord developer mode, right-click channel → Copy ID
# ---------------------------------------------------------------------------
# COUNCIL_DISCORD_GUILD_ID=YOUR_GUILD_ID
# COUNCIL_DISCORD_CHANNEL_ID=YOUR_CHANNEL_ID
# COUNCIL_DISCORD_FORUM_ID=YOUR_FORUM_CHANNEL_ID   (optional, for thread posts)
# COUNCIL_DISCORD_THREAD_ID=YOUR_THREAD_ID         (optional, for thread replies)

# Mention a user when posting to Discord (optional)
# COUNCIL_DISCORD_MENTION_USER_ID=YOUR_DISCORD_USER_ID

# ---------------------------------------------------------------------------
# OpenClaw Main-Seat Notification (OPTIONAL)
# ---------------------------------------------------------------------------
# By default, the council notifies your OpenClaw agent when done.
# Set the target agent or session below.
#
# Default target (recommended): agent=main
# ---------------------------------------------------------------------------
# COUNCIL_OPENCLAW_AGENT=main

# Or target a specific session (get session ID from openclaw sessions list)
# COUNCIL_SESSION_ID=YOUR_SESSION_ID

# ---------------------------------------------------------------------------
# Tuning (OPTIONAL — defaults shown)
# ---------------------------------------------------------------------------
# COUNCIL_LOG_LEVEL=info
# COUNCIL_MAX_RETRIES=2
# COUNCIL_API_TIMEOUT=180

# ---------------------------------------------------------------------------
# Dry Run Mode (set to 1 to skip external calls during testing)
# ---------------------------------------------------------------------------
# COUNCIL_DISCORD_DRY_RUN=0
# COUNCIL_OPENCLAW_DRY_RUN=0
